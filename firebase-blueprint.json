{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Student record for Jamia",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "fatherName": { "type": "string" },
        "phone": { "type": "string" },
        "gmail": { "type": "string" },
        "address": { "type": "string" },
        "zaat": { "type": "string" },
        "age": { "type": "string" },
        "rollNumber": { "type": "string" },
        "password": { "type": "string" },
        "admissionDate": { "type": "string" },
        "reference": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["name", "fatherName", "phone", "rollNumber", "password"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "description": "ISO Date" },
        "status": { "type": "string", "enum": ["present", "absent", "leave"] }
      },
      "required": ["studentId", "date", "status"]
    },
    "Report": {
      "title": "Report",
      "description": "Daily academic and behavioral report",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string" },
        "sabaq": { "type": "string" },
        "sabqi": { "type": "string" },
        "manzil": { "type": "string" },
        "dua": { "type": "string" },
        "namaz": { "type": "string" },
        "behavioral": { "type": "string" }
      },
      "required": ["studentId", "date"]
    },
    "Finance": {
      "title": "Finance",
      "description": "Income and expense records",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "donorName": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["type", "amount", "date"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "The main collection of students"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance logs"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Student daily reports"
    },
    "/finance/{financeId}": {
      "schema": "Finance",
      "description": "Accounting records"
    }
  }
}
